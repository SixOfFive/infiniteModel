# The offline bundle (standalone Python runtimes python/ + the full wheel cache
# wheels/) is NOT vendored in the public repo — it was ~550 MB. install.sh /
# install.bat install from PyPI online; for a fully offline build, drop your own
# wheels/ + python/ here (they are ignored below so they never get committed).
wheels/
python/

# TARGET-GENERATED, machine-specific build outputs — install.* recreate them on
# each machine and they must NOT be committed (a venv bakes absolute paths;
# runtime/ is just python/*.tar.gz unpacked).
.venv-win/
.venv-linux/
runtime/
